<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_glass"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="من أنت؟ 💜"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- Essa Option -->
        <LinearLayout
            android:id="@+id/btnSelectEssa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/chip_idle"
            android:padding="16dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="ع"
                android:textColor="#E9D5FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/avatar_essa" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عيسى"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Hazama Option -->
        <LinearLayout
            android:id="@+id/btnSelectHazama"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/chip_idle"
            android:padding="16dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="هـ"
                android:textColor="#FCE7F3"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/avatar_hazama" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حزامه"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
