<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="70dp"
        android:paddingBottom="50dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <!-- Rings -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center">
            <View android:layout_width="200dp" android:layout_height="200dp"
                android:layout_gravity="center" android:background="@drawable/ring_outer"/>
            <View android:layout_width="154dp" android:layout_height="154dp"
                android:layout_gravity="center" android:background="@drawable/ring_mid"/>
            <View android:layout_width="108dp" android:layout_height="108dp"
                android:layout_gravity="center" android:background="@drawable/ring_inner"/>
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="💜" android:textSize="46sp"/>
        </FrameLayout>

        <!-- Tagline -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="28dp" android:text="@string/our_love_app"
            android:textColor="#A78BFA" android:textSize="13sp"
            android:letterSpacing="0.15" android:textStyle="italic"/>

        <!-- Essa -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:text="@string/essa"
            android:textColor="#F9A8D4" android:textSize="48sp" android:textStyle="bold"/>

        <!-- & Hazama -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&amp; حزامه" android:textColor="#FFFFFF"
            android:textSize="36sp" android:textStyle="bold"/>

        <!-- Since date -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:text="@string/together_since"
            android:textColor="#9F7AEA" android:textSize="13sp"/>

        <!-- Counter Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:background="@drawable/counter_card"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="28dp" android:paddingBottom="28dp"
            android:paddingStart="20dp" android:paddingEnd="20dp">

            <!-- Days Number -->
            <TextView android:id="@+id/tvDaysCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0" android:textColor="#D8B4FE"
                android:textSize="80sp" android:textStyle="bold"
                android:lineSpacingExtra="-10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="@string/days_of_love"
                android:textColor="#F9A8D4" android:textSize="15sp"/>

            <!-- FIX: H : M : S live ticker -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center">

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/chip_idle"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:paddingTop="7dp" android:paddingBottom="7dp">
                    <TextView android:id="@+id/tvSplashHours"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="00" android:textColor="#E9D5FF"
                        android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/hours_label" android:textColor="#A78BFA" android:textSize="9sp"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" : " android:textColor="#C4B5FD"
                    android:textSize="22sp" android:textStyle="bold"/>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/chip_idle"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:paddingTop="7dp" android:paddingBottom="7dp">
                    <TextView android:id="@+id/tvSplashMinutes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="00" android:textColor="#E9D5FF"
                        android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/minutes_label" android:textColor="#A78BFA" android:textSize="9sp"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" : " android:textColor="#C4B5FD"
                    android:textSize="22sp" android:textStyle="bold"/>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/chip_idle"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:paddingTop="7dp" android:paddingBottom="7dp">
                    <TextView android:id="@+id/tvSplashSeconds"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="00" android:textColor="#F9A8D4"
                        android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/seconds_label" android:textColor="#A78BFA" android:textSize="9sp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Enter Button -->
        <Button android:id="@+id/btnEnter"
            android:layout_width="match_parent" android:layout_height="58dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/btn_primary"
            android:text="@string/enter_our_world"
            android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"
            android:stateListAnimator="@null" android:elevation="0dp"/>

    </LinearLayout>
</ScrollView>
