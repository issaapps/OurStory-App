<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/card_white"
    android:layout_margin="5dp">

    <FrameLayout android:id="@+id/memImgArea"
        android:layout_width="match_parent" android:layout_height="100dp"
        android:background="@drawable/memory_img_bg">
        <TextView android:id="@+id/tvMemEmoji"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:text="💜" android:textSize="40sp"/>
        <!-- star badge for favourite -->
        <TextView android:id="@+id/tvFavStar"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="top|end" android:layout_margin="8dp"
            android:text="⭐" android:textSize="16sp" android:visibility="gone"/>
    </FrameLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">
        <TextView android:id="@+id/tvMemName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ذكرى" android:textColor="@color/text_primary"
            android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvMemDate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="2025" android:textColor="@color/text_secondary" android:textSize="11sp"/>
        <!-- Description line (new) -->
        <TextView android:id="@+id/tvMemDesc"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="" android:textColor="@color/text_soft"
            android:textSize="10sp" android:textStyle="italic"
            android:maxLines="2" android:ellipsize="end" android:visibility="gone"/>
        <TextView android:id="@+id/tvMemTag"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="خاص" android:textColor="@color/purple_mid"
            android:textSize="9sp" android:textStyle="bold"
            android:background="@drawable/chip_idle"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:paddingTop="3dp" android:paddingBottom="3dp"/>
    </LinearLayout>

</LinearLayout>
