<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingTop="24dp" android:paddingBottom="12dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/daily_message" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvMsgDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="اليوم" android:textColor="#A78BFA" android:textSize="12sp" android:background="@drawable/chip_idle" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="8dp" android:paddingBottom="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:scrollbars="none">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="16dp">

            <!-- Hero Message -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="14dp" android:background="@drawable/card_white" android:orientation="vertical" android:gravity="center" android:padding="24dp">

                <TextView android:id="@+id/tvMsgHeart" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💜" android:textSize="44sp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="غَزَل اليوم لحزامه" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.08"/>

                <View android:layout_width="60dp" android:layout_height="1dp" android:background="#44A855F7" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>

                <TextView android:id="@+id/tvDailyMessage"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="يا من سكنتِ فؤادي والروح تطلبكِ…\nأنتِ الحياةُ وفي عينيكِ أوطاني."
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:lineSpacingExtra="6dp" android:textStyle="italic"
                    android:gravity="center"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="— Essa لحزامه 💕" android:textColor="@color/pink_rose" android:textSize="12sp" android:textStyle="bold"/>

                <!-- Reaction Row -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center">
                    <Button android:id="@+id/btnLoveReact" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginEnd="8dp" android:text="💜 أحبك" android:textColor="@color/text_secondary" android:textSize="12sp" android:background="@drawable/chip_idle" android:stateListAnimator="@null" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                    <Button android:id="@+id/btnReplyReact" android:layout_width="wrap_content" android:layout_height="40dp" android:text="💌 رد بحب" android:textColor="@color/text_secondary" android:textSize="12sp" android:background="@drawable/chip_idle" android:stateListAnimator="@null" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Previous Messages -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:layout_marginBottom="10dp" android:text="@string/prev_messages" android:textColor="#D8B4FE" android:textSize="14sp" android:textStyle="bold"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="8dp" android:background="@drawable/card_white" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/dot_purple" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="«أنتِ النور الذي يضيء عتمي، أحبك يا حزامه»" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="italic"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="أمس" android:textColor="@color/text_soft" android:textSize="10sp" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="8dp" android:background="@drawable/card_white" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/dot_pink" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="«كل يوم معكِ هو عمر جديد، ربي لا يحرمني منك»" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="italic"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قبل يومين" android:textColor="@color/text_soft" android:textSize="10sp" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="14dp" android:background="@drawable/card_white" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp">
                <View android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/dot_green" android:layout_marginEnd="12dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="«حزامه.. يا أجمل صدفة في حياتي»" android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="italic"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قبل ٣ أيام" android:textColor="@color/text_soft" android:textSize="10sp" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Write New Message -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:layout_marginBottom="10dp" android:text="@string/write_new_msg" android:textColor="#D8B4FE" android:textSize="14sp" android:textStyle="bold"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:background="@drawable/card_white" android:orientation="vertical" android:padding="16dp">

                <EditText android:id="@+id/etNewMessage"
                    android:layout_width="match_parent" android:layout_height="110dp"
                    android:hint="@string/write_message_hint" android:hintTextColor="#A78BFA"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:background="@drawable/input_bg" android:padding="14dp"
                    android:gravity="top|end" android:inputType="textMultiLine" android:lines="4"/>

                <Button android:id="@+id/btnSendMessage"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/send"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
                    android:background="@drawable/btn_primary" android:stateListAnimator="@null"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
