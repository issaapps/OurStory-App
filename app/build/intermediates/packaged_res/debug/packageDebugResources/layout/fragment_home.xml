<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Top Bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingBottom="20dp" android:gravity="center_vertical" android:baselineAligned="false">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/welcome_back" android:textColor="#A78BFA" android:textSize="13sp"/>
                <TextView android:id="@+id/tvGreeting" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_name" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:layout_width="46dp" android:layout_height="46dp" android:text="💜" android:textSize="24sp" android:gravity="center" android:background="@drawable/chip_idle"/>
        </LinearLayout>

        <!-- Couple Hero Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_glass"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="64dp" android:layout_height="64dp" android:text="ع" android:textColor="#E9D5FF" android:textSize="26sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/avatar_essa"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/essa" android:textColor="#D8B4FE" android:textSize="12sp" android:layout_marginTop="8dp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp">
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#44D8B4FE"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💜 💕 💜" android:textSize="18sp" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#44D8B4FE"/>
                <TextView android:id="@+id/tvDaysHome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="441 يوم معاً 💕" android:textColor="#D8B4FE" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="10dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="64dp" android:layout_height="64dp" android:text="هـ" android:textColor="#FCE7F3" android:textSize="26sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/avatar_hazama"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/hazama" android:textColor="#F9A8D4" android:textSize="12sp" android:layout_marginTop="8dp" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Quick Grid 2x2 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <LinearLayout android:id="@+id/cardQuickCounter" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:background="@drawable/card_white" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💜" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/counter" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/tvQuickDays" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="441 يوم" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cardQuickMessage" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:background="@drawable/card_white" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💌" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/messages" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tap_to_read" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cardQuickMemories" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:background="@drawable/card_white" android:orientation="vertical" android:gravity="center" android:clickable="true" android:focusable="true" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📸" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/memories" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24 لحظة" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:background="@drawable/card_white" android:orientation="vertical" android:gravity="center" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/milestones" android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12 موعد" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="3dp"/>
            </LinearLayout>

        </GridLayout>

        <!-- Daily Gazal Quote Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/quote_card"
            android:orientation="vertical"
            android:padding="22dp"
            android:gravity="end">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/today_quote" android:textColor="#A78BFA" android:textSize="11sp" android:letterSpacing="0.1" android:textStyle="bold"/>

            <TextView android:id="@+id/tvQuote" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp"
                android:text="&quot;كل يوم معكِ هو أجمل يوم في حياتي.&quot;"
                android:textColor="#FFFFFF" android:textSize="15sp" android:lineSpacingExtra="6dp" android:textStyle="italic" android:gravity="end"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/quote_author" android:textColor="#F9A8D4" android:textSize="12sp" android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
