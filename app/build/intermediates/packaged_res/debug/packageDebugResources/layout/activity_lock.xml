<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_main"
    android:paddingStart="32dp"
    android:paddingEnd="32dp">

    <!-- Icon -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="💜" android:textSize="64sp"
        android:layout_marginBottom="16dp"/>

    <!-- Title -->
    <TextView android:id="@+id/tvLockTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="أهلاً" android:textColor="#FFFFFF"
        android:textSize="28sp" android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView android:id="@+id/tvLockSubtitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="أدخل رقمك السري"
        android:textColor="#A78BFA" android:textSize="15sp"
        android:layout_marginBottom="40dp"/>

    <!-- PIN dots -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:layout_marginBottom="48dp">

        <TextView android:id="@+id/tvPinDisplay"
            android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        <View android:id="@+id/dot1"
            android:layout_width="18dp" android:layout_height="18dp"
            android:background="@drawable/dot_pin_empty"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>
        <View android:id="@+id/dot2"
            android:layout_width="18dp" android:layout_height="18dp"
            android:background="@drawable/dot_pin_empty"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>
        <View android:id="@+id/dot3"
            android:layout_width="18dp" android:layout_height="18dp"
            android:background="@drawable/dot_pin_empty"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>
        <View android:id="@+id/dot4"
            android:layout_width="18dp" android:layout_height="18dp"
            android:background="@drawable/dot_pin_empty"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>
    </LinearLayout>

    <!-- Keypad -->
    <GridLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:columnCount="3" android:rowCount="4"
        android:layoutDirection="ltr"
        android:layout_marginBottom="24dp">

        <!-- Row 1: 1 2 3 -->
        <TextView android:id="@+id/btn1" android:layout_width="80dp" android:layout_height="80dp"
            android:text="1" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btn2" android:layout_width="80dp" android:layout_height="80dp"
            android:text="2" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btn3" android:layout_width="80dp" android:layout_height="80dp"
            android:text="3" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>

        <!-- Row 2: 4 5 6 -->
        <TextView android:id="@+id/btn4" android:layout_width="80dp" android:layout_height="80dp"
            android:text="4" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btn5" android:layout_width="80dp" android:layout_height="80dp"
            android:text="5" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btn6" android:layout_width="80dp" android:layout_height="80dp"
            android:text="6" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>

        <!-- Row 3: 7 8 9 -->
        <TextView android:id="@+id/btn7" android:layout_width="80dp" android:layout_height="80dp"
            android:text="7" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btn8" android:layout_width="80dp" android:layout_height="80dp"
            android:text="8" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/btn9" android:layout_width="80dp" android:layout_height="80dp"
            android:text="9" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>

        <!-- Row 4: biometric 0 delete -->
        <ImageView android:id="@+id/btnBiometric"
            android:layout_width="80dp" android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#A78BFA" android:scaleType="center"
            android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"
            android:visibility="gone"/>

        <TextView android:id="@+id/btn0" android:layout_width="80dp" android:layout_height="80dp"
            android:text="0" android:textColor="#FFFFFF" android:textSize="28sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btnDelete"
            android:layout_width="80dp" android:layout_height="80dp"
            android:text="⌫" android:textColor="#A78BFA" android:textSize="24sp"
            android:gravity="center" android:background="@drawable/btn_pin"
            android:layout_margin="6dp" android:clickable="true" android:focusable="true"/>

    </GridLayout>

</LinearLayout>
